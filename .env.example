# Capital FM Election Watch — environment configuration
#
# Copy this file to `.env` and fill in your API key. The .env file is
# git-ignored — it stays on this laptop.
#
# Required: at least one of ANTHROPIC_API_KEY or OPENAI_API_KEY.
# Anthropic (Claude) is the recommended default.

# ─── Required: API key ─────────────────────────────────────────────

# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=

# OpenAI (alternative — leave blank if using Anthropic)
# OPENAI_API_KEY=

# ─── Optional ──────────────────────────────────────────────────────

# Force a specific provider. Leave commented to auto-detect from
# whichever key is set.
# AI_PROVIDER=anthropic

# Override the default model. Defaults:
#   anthropic → claude-haiku-4-5
#   openai    → gpt-5.4-mini
# MODEL=claude-opus-4-7

# Override the HTTP port (default 3000).
# PORT=3000
